      <column caption='Filter Outliers TURBON' datatype='real' name='[Calculation_1431077357289473]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SUM([Line.Total]) &lt; 150000 THEN SUM([Line.Total]) END' />
      </column>
      <column caption='Rolling Avg Spend' datatype='real' name='[Calculation_1431077360902146]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_AVG(SUM([Line.Total]), -2, 0)'>
